# Critical runtime overrides loaded from the same directory as `config.yaml`.

# Server listen address. Use one of the two forms below.
JC_PROXY_SERVER_LISTEN=:8092
# JC_PROXY_SERVER_PORT=8092

# Optional admin CIDR allowlist. Comma or newline separated.
# Leave unset to disable source-IP filtering entirely.
# JC_PROXY_ADMIN_ALLOWED_CIDRS=10.0.0.0/8,192.168.0.0/16

# Switch both config storage and upstream key storage to PostgreSQL.
JC_PROXY_STORAGE_MODE=pgsql

# Shared PostgreSQL DSN for both storage backends.
JC_PROXY_STORAGE_PGSQL_DSN=postgres://postgres:postgres@127.0.0.1:5432/jc_proxy?sslmode=disable

# Optional pool settings shared by both PostgreSQL backends.
# JC_PROXY_STORAGE_PGSQL_MAX_OPEN_CONNS=4
# JC_PROXY_STORAGE_PGSQL_MAX_IDLE_CONNS=2
# JC_PROXY_STORAGE_PGSQL_CONN_MAX_LIFETIME=30m

# Optional per-store overrides.
# JC_PROXY_STORAGE_CONFIG_PGSQL_TABLE=jc_proxy_configs
# JC_PROXY_STORAGE_CONFIG_PGSQL_RECORD_KEY=default
# JC_PROXY_STORAGE_UPSTREAM_KEYS_PGSQL_TABLE=jc_proxy_upstream_keys
# JC_PROXY_STORAGE_UPSTREAM_KEYS_FILE_PATH=./data/upstream_keys.json
